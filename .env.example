# PostgreSQL
POSTGRES_USER=shopflow
POSTGRES_PASSWORD=shopflow_secret
POSTGRES_DB=shopflow

# Per-service DB URLs
USER_DATABASE_URL=postgresql+asyncpg://shopflow:shopflow_secret@postgres:5432/shopflow_users
PRODUCT_DATABASE_URL=postgresql+asyncpg://shopflow:shopflow_secret@postgres:5432/shopflow_products
ORDER_DATABASE_URL=postgresql+asyncpg://shopflow:shopflow_secret@postgres:5432/shopflow_orders

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# JWT
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
